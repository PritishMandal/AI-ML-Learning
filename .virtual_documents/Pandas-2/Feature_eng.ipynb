# Melt & Pivot

df = pd.DataFrame({
    "country":["USA","USA","India","India"],
    "Year":[2020,2021,2020,2021],
    "sales":[100,120,90,110],
    "profit":[20,25,18,22],
    "tax":[10,20,30,40]
})
melted_df=df.melt(
    id_vars=["country","year"],
    value_vara=["sales","profit"],
    var_name="matrics",
    value_name="value"
)
original = melted_df.pivot(
    index=["country","year"],
    colums="metrics"
    values="value"
)


